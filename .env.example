# ─── Required in all environments ────────────────────────────────────────

# Postgres connection string. Vercel Postgres / Neon / Supabase all provide this.
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── Solana ──────────────────────────────────────────────────────────────

# Primary RPC. Paid plan recommended (Helius/Triton/QuickNode).
MAINNET_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
# Optional devnet fallback. Not used in production.
DEVNET_RPC_URL="https://api.devnet.solana.com"
SOLANA_NETWORK="mainnet-beta"

# Platform treasury public key. Withdrawals will originate from this address.
PLATFORM_TREASURY_PUBKEY=""

# ─── Helius (deposit indexer) ────────────────────────────────────────────

HELIUS_API_KEY=""
# A long random string used to HMAC-sign webhook payloads. Set the same value
# in the Helius dashboard when you create the webhook.
HELIUS_WEBHOOK_SECRET=""

# ─── Session signing ─────────────────────────────────────────────────────

# 32+ random bytes, base64 or hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_JWT_SECRET=""

# ─── Game service (Fly.io) ───────────────────────────────────────────────

# Internal HTTPS URL of the Fly.io game service. The Next.js frontend posts
# bet/withdrawal requests here. Not exposed to the public.
GAME_SERVICE_URL="https://rushsol-game.flycast"
# Shared secret between Vercel and Fly. Set both sides to the same value.
GAME_SERVICE_API_KEY=""

# ─── Treasury / Fireblocks (Phase 5) ─────────────────────────────────────

FIREBLOCKS_API_KEY=""
FIREBLOCKS_API_SECRET=""
FIREBLOCKS_VAULT_ACCOUNT_ID=""

# ─── KYC (Phase 6) ───────────────────────────────────────────────────────

KYC_PROVIDER="sumsub"
SUMSUB_APP_TOKEN=""
SUMSUB_SECRET_KEY=""
SUMSUB_WEBHOOK_SECRET=""

# ─── Geofencing (Phase 7) ────────────────────────────────────────────────

# ISO 3166-1 alpha-2 codes, comma-separated, lowercase. The middleware will
# reject requests whose country appears in this list. Curate against your
# actual license; do not use this list as legal advice.
BLOCKED_COUNTRIES="us,gb,au,jp"

# ─── Devnet-only toggle ──────────────────────────────────────────────────

# When true, the app stays in mock-balance mode. Deposit/withdrawal flows
# are disabled. Set to false in any environment that handles real SOL.
ENABLE_MOCK_BALANCE="true"

# ─── Public (inlined at build time) ──────────────────────────────────────

NEXT_PUBLIC_SOLANA_NETWORK="mainnet-beta"
NEXT_PUBLIC_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
NEXT_PUBLIC_PLATFORM_NAME="RushSol"
